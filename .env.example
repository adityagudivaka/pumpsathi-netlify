# Set these in Netlify ▸ Site settings ▸ Environment variables
APP_NAME=PumpSathi
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=12h

# Bootstrap owner login (created on first request). Username = MOBILE number.
OWNER_MOBILE=9999999999
OWNER_PASSWORD=admin123
OWNER_FIRM_NAME=Aditya Filling Station

# WhatsApp (Meta Cloud API) — leave blank for preview/dry-run mode
WA_PROVIDER=meta
WA_TOKEN=
WA_PHONE_ID=
WA_API_VERSION=v21.0
# Twilio alternative (WA_PROVIDER=twilio)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
